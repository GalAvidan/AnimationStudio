    "@motion-canvas/core": { "optional": true }
  },
  "devDependencies": {
    "@motion-canvas/2d": "^3.0.0",
    "@motion-canvas/core": "^3.0.0",
    "@studio/config-tsconfig": "workspace:*",
    "@studio/config-eslint": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": ">=5.4"
  }
